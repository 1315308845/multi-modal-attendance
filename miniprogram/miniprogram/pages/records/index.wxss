/* pages/records/index.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.refresh-btn {
  margin: 20rpx auto;
  display: block;
  width: 200rpx;
}

.record-list {
  margin-top: 20rpx;
}

.record-item {
  background: white;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
}

.student-id {
  font-size: 28rpx;
  color: #666;
  background: #f0f0f0;
  padding: 5rpx 15rpx;
  border-radius: 8rpx;
}

.record-time {
  font-size: 26rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 32rpx;
}

.footer {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}